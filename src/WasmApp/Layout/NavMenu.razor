@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Sections
@using WasmApp.Services

@inject IUserClient userClient

@rendermode InteractiveWebAssembly

@* Single nav row - elements show/hide per viewport via mobile-only/desktop-only *@
<div class="nav-row">
    @* Mobile only: hamburger + page title *@
    <span class="page-title-wrap mobile-only" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
        <SectionOutlet SectionName="page-title" />
    </span>

    @* Desktop only: brand *@
    <a class="desktop-nav-brand desktop-only" href="/">RssReader</a>

    @* Desktop only: nav links *@
    <div class="desktop-nav-links desktop-only">
        <AuthorizeView>
            <Authorized>
                <NavLink class="desktop-nav-link" href="/timeline" Match="NavLinkMatch.Prefix">Timeline</NavLink>
                <NavLink class="desktop-nav-link" href="/search" Match="NavLinkMatch.Prefix">Search</NavLink>
                <NavLink class="desktop-nav-link" href="/feeds" Match="NavLinkMatch.Prefix">Feeds</NavLink>
                <NavLink class="desktop-nav-link" href="/tags" Match="NavLinkMatch.Prefix">Tags</NavLink>
                <NavLink class="desktop-nav-link" href="/privacy" Match="NavLinkMatch.Prefix">Privacy</NavLink>
            </Authorized>
            <NotAuthorized>
                <NavLink class="desktop-nav-link" href="/privacy" Match="NavLinkMatch.Prefix">Privacy</NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    @* Always visible: toolbar (single SectionOutlet - works on both mobile and desktop) *@
    <div class="toolbar-container">
        <SectionOutlet SectionName="toolbar" />
    </div>

    @* Desktop only: auth *@
    <div class="desktop-nav-auth desktop-only">
        <AuthorizeView>
            <Authorized>
                <a class="desktop-nav-link" href="/.auth/logout">Logout</a>
            </Authorized>
            <NotAuthorized>
                <a class="desktop-nav-link" href="/.auth/login/aad">Login</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@* Mobile slide-in nav menu *@
<div class="@NavMenuCssClass nav-menu mobile-only" @onclick="CollapseNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <span class="navbar-toggler-icon"></span>
            <a style="text-decoration: none; color: inherit;" href="/">RssReader</a>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/timeline">
                        Timeline
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/search">
                        Search
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/feeds">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Feeds
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/tags">
                        Tags
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/privacy">
                        Privacy Policy
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="/.auth/logout">
                        Logout
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/.auth/login/aad">
                        Login
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/privacy">
                        Privacy Policy
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string username = null;
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        username = await userClient.GetUsernameAsync();
        if (string.IsNullOrEmpty(username))
        {
            username = "Guest";
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CollapseNavMenu()
    {
        collapseNavMenu = true;
    }
}