@using RssApp.Contracts
@inherits PageBase
@implements IDisposable
@inject ILogger<PostPageBase> logger
@inject IJSRuntime jsRuntime
@inject NavigationManager NavigationManager

@code {
    private bool _isRefreshing;
    private string _scrollAnchorPostId;
    private bool _needsScrollRestore;
    private int _restorePageSize;
    public List<NewsFeedItem> Items { get; set; } = new List<NewsFeedItem>();
    public int Page { get; set; } = 0;
    public long? CursorPublishDateOrder { get; set; }
    public long? CursorId { get; set; }
    protected bool initialized = false;

    protected class ScrollState
    {
        public string PostId { get; set; }
        public int Page { get; set; }
        public string Path { get; set; }
    }

    public void Dispose()
    {
        this.Items.Clear();
    }

    protected virtual string GetBasePath() => "/timeline";
    protected virtual Dictionary<string, string> GetExtraQueryParams() => new();

    protected virtual Task<List<NewsFeedItem>> GetPostsAsync(int pageSize = 20)
    {
        // overridden
        throw new NotImplementedException();
    }

    protected void ResetPagination()
    {
        Items.Clear();
        Page = 0;
        CursorPublishDateOrder = null;
        CursorId = null;
    }

    protected void UpdateCursorFromItems(IEnumerable<NewsFeedItem> items)
    {
        var lastItem = items.LastOrDefault();
        if (lastItem != null && long.TryParse(lastItem.Id, out var parsedId))
        {
            CursorPublishDateOrder = lastItem.PublishDateOrder;
            CursorId = parsedId;
        }
    }

    protected async Task UpdatePage(int page)
    {
        if (!initialized || _isRefreshing)
        {
            return;
        }

        Page = page;
        await this.RefreshItems((this.feedClient.IsFilterUnread, this.feedClient.IsFilterSaved, this.feedClient.FilterTag));
    }

    protected async Task RefreshItems((bool isFilterUnread, bool isFilterSaved, string filterTag) filters)
    {
        if (_isRefreshing)
        {
            return;
        }

        try
        {
            _isRefreshing = true;
            
            if (UpdateFilters(filters))
            {
                ResetPagination();
                UpdateUrlFromFilters();
            }

            int pageSize = _restorePageSize > 0 ? _restorePageSize : 20;
            _restorePageSize = 0;
            
            var newPageRes = await this.GetPostsAsync(pageSize);
            // Deduplicate by Href before adding
            var existingHrefs = new HashSet<string>(Items.Select(i => i.Href), StringComparer.OrdinalIgnoreCase);
            var dedupedNewPosts = newPageRes.Where(i => !existingHrefs.Contains(i.Href)).ToList();
            Items.AddRange(dedupedNewPosts);

            // Update cursor from the new page results (not deduplicated — use original to get true last item)
            if (newPageRes.Any())
            {
                UpdateCursorFromItems(newPageRes);
            }
            
            this.StateHasChanged();
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private bool UpdateFilters((bool isFilterUnread, bool isFilterSaved, string filterTag) filters)
    {
        bool hasChanged = filters.isFilterUnread != this.feedClient.IsFilterUnread
            || filters.isFilterSaved != this.feedClient.IsFilterSaved
            || filters.filterTag != this.feedClient.FilterTag;

        if (hasChanged)
        {
            this.feedClient.IsFilterUnread = filters.isFilterUnread;
            this.feedClient.IsFilterSaved = filters.isFilterSaved;
            this.feedClient.FilterTag = filters.filterTag;
        }

        return hasChanged;
    }

    protected void ApplyFiltersFromUrl()
    {
        var qs = ParseQueryString(NavigationManager.Uri);
        this.feedClient.IsFilterUnread = qs.TryGetValue("unread", out var u) && u == "true";
        this.feedClient.IsFilterSaved = qs.TryGetValue("saved", out var s) && s == "true";
        this.feedClient.FilterTag = qs.TryGetValue("tag", out var t) ? t : null;
    }

    protected void UpdateUrlFromFilters()
    {
        var queryParams = new Dictionary<string, string>();
        if (feedClient.IsFilterUnread) queryParams["unread"] = "true";
        if (feedClient.IsFilterSaved) queryParams["saved"] = "true";
        if (!string.IsNullOrEmpty(feedClient.FilterTag)) queryParams["tag"] = feedClient.FilterTag;

        foreach (var kv in GetExtraQueryParams())
            if (!string.IsNullOrEmpty(kv.Value))
                queryParams[kv.Key] = kv.Value;

        var path = GetBasePath();
        var url = queryParams.Count > 0
            ? path + "?" + string.Join("&", queryParams.Select(kv => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value)}"))
            : path;

        var currentRelative = "/" + NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var currentPath = currentRelative.Contains('?') ? currentRelative[..currentRelative.IndexOf('?')] : currentRelative;
        var newPath = url.Contains('?') ? url[..url.IndexOf('?')] : url;

        // Only navigate if something actually changed (compare full normalized URLs)
        var currentQs = ParseQueryString(NavigationManager.Uri);
        var newQs = ParseQueryString("http://x" + url);
        if (currentPath != newPath || !QueryParamsEqual(currentQs, newQs))
        {
            NavigationManager.NavigateTo(url, replace: true);
        }
    }

    private static bool QueryParamsEqual(Dictionary<string, string> a, Dictionary<string, string> b)
    {
        if (a.Count != b.Count) return false;
        foreach (var kv in a)
        {
            if (!b.TryGetValue(kv.Key, out var val) || val != kv.Value) return false;
        }
        return true;
    }

    private static Dictionary<string, string> ParseQueryString(string uri)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var qIndex = uri.IndexOf('?');
        if (qIndex < 0) return result;
        var query = uri[(qIndex + 1)..];
        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var eqIndex = pair.IndexOf('=');
            if (eqIndex > 0)
                result[Uri.UnescapeDataString(pair[..eqIndex])] = Uri.UnescapeDataString(pair[(eqIndex + 1)..]);
        }
        return result;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            this.initialized = true;

            // Apply filter state from URL query parameters
            ApplyFiltersFromUrl();

            // Check for scroll restoration from sessionStorage
            try
            {
                var scrollState = await jsRuntime.InvokeAsync<ScrollState>("rssApp.getScrollState");
                if (scrollState != null && scrollState.Path == GetBasePath())
                {
                    _scrollAnchorPostId = scrollState.PostId;
                    _needsScrollRestore = true;
                    _restorePageSize = Math.Min((scrollState.Page + 2) * 20, 500);
                    await jsRuntime.InvokeVoidAsync("rssApp.clearScrollState");
                }
            }
            catch (Exception)
            {
                // sessionStorage may be unavailable
            }

            if (this.Items == null || !this.Items.Any())
            {
                await this.RefreshItems((this.feedClient.IsFilterUnread, this.feedClient.IsFilterSaved, this.feedClient.FilterTag));
            }
        }
        else if (_needsScrollRestore && !string.IsNullOrEmpty(_scrollAnchorPostId))
        {
            try
            {
                var scrolled = await jsRuntime.InvokeAsync<bool>("rssApp.scrollToPost", _scrollAnchorPostId);
                if (scrolled)
                {
                    _needsScrollRestore = false;
                    _scrollAnchorPostId = null;
                }
            }
            catch (Exception)
            {
                _needsScrollRestore = false;
            }
        }
    }
}
