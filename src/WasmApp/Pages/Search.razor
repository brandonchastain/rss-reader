@page "/search"
@inherits PostPageBase
@inject ILogger<Search> logger
@rendermode InteractiveWebAssembly
@attribute [StreamRendering]
@attribute [Authorize]

<PageTitle>Search</PageTitle>
<SectionContent SectionName="page-title">| Search</SectionContent>

<div class="input-group mb-3">
    <input @bind="searchTerm" @bind:event="oninput" placeholder="Search..." class="form-control" @onkeydown="(e) => OnKeyDown(e)" />
    <button class="btn btn-primary" @onclick="() => SearchPosts()"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (hasSearched && !Items.Any())
{
    <div class="alert alert-warning">No results found. Try a different search.</div>
}
else if (hasSearched)
{
    <CascadingValue Value="@Page" Name="Page">
    <CascadingValue Value="@Items" Name="Posts">
        <PostTable OnPageChanged="UpdatePage" FeedClient="@this.feedClient" OnRefreshTriggered="RefreshItems"/>
    </CascadingValue>
    </CascadingValue>
}

@code {
    private string searchTerm = string.Empty;
    private bool hasSearched = false;
    private string errorMessage = string.Empty;

    [SupplyParameterFromQuery(Name = "q")]
    public string QueryParam { get; set; }

    protected override string GetBasePath() => "/search";

    protected override Dictionary<string, string> GetExtraQueryParams()
    {
        var extra = new Dictionary<string, string>();
        if (!string.IsNullOrEmpty(searchTerm)) extra["q"] = searchTerm;
        return extra;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Apply filters from URL
            ApplyFiltersFromUrl();
            initialized = true;

            // If search query is in URL, auto-search
            if (!string.IsNullOrWhiteSpace(QueryParam))
            {
                searchTerm = QueryParam;
                await SearchPosts();
            }
        }
        // Skip base OnAfterRenderAsync — search only loads on explicit action
    }

    protected override async Task<List<NewsFeedItem>> GetPostsAsync(int pageSize = 20)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            return new List<NewsFeedItem>();
        }

        var res = await feedClient.SearchItemsAsync(searchTerm, Page, pageSize: pageSize);
        return res.ToList();
    }

    private async Task SearchPosts()
    {
        try
        {
            errorMessage = string.Empty;
            Page = 0;
            CursorPublishDateOrder = null;
            CursorId = null;
            var newItems = await this.GetPostsAsync();
            Items = newItems;
            hasSearched = true;
            UpdateUrlFromFilters();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Search failed for term: {SearchTerm}", searchTerm);
            errorMessage = "Search failed. Please try again later.";
            hasSearched = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchPosts();
        }
    }
}