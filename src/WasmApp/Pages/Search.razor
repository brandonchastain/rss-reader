@page "/search"
@inherits PostPageBase
@inject ILogger<Search> logger
@rendermode InteractiveWebAssembly
@attribute [StreamRendering]
@attribute [Authorize]

<PageTitle>Search</PageTitle>
<SectionContent SectionName="page-title">| Search</SectionContent>

<div class="input-group mb-3">
    <input @bind="searchTerm" @bind:event="oninput" placeholder="Search..." class="form-control" @onkeydown="(e) => OnKeyDown(e)" />
    <button class="btn btn-primary" @onclick="() => SearchPosts()"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
</div>

@if (hasSearched && !Items.Any())
{
    <div class="alert alert-warning">No results found. Try a different search.</div>
}
else if (hasSearched)
{
    <CascadingValue Value="@Page" Name="Page">
    <CascadingValue Value="@Items" Name="Posts">
        <PostTable OnPageChanged="UpdatePage" FeedClient="@this.feedClient" OnRefreshTriggered="RefreshItems"/>
    </CascadingValue>
    </CascadingValue>
}

@code {
    private string searchTerm = string.Empty;
    private bool hasSearched = false;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        // Skip base initialization so the empty state doesn't auto-trigger
        return Task.CompletedTask;
    }

    protected override async Task<List<NewsFeedItem>> GetPostsAsync()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            return new List<NewsFeedItem>();
        }

        var res = await feedClient.SearchItemsAsync(searchTerm, Page);
        return res.ToList();
    }

    private async Task SearchPosts()
    {
        Items = await this.GetPostsAsync();
        hasSearched = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchPosts();
        }
    }
}