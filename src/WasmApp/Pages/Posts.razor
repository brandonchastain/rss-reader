@page "/posts"
@using WasmApp.Pages.Detail
@inherits PostPageBase
@rendermode InteractiveWebAssembly
@attribute [StreamRendering]
@attribute [Authorize]
@inject ILogger<Posts> logger
@inject IJSRuntime jsRuntime
@inject NavigationManager NavigationManager


<PageTitle>Posts</PageTitle>
<SectionContent SectionName="page-title">Posts from @Href?.GetRootDomain()</SectionContent>

<CascadingValue Value="@Page" Name="Page">
<CascadingValue Value="@Items" Name="Posts">
    <PostTable OnPageChanged="UpdatePage" FeedClient="@this.feedClient" OnRefreshTriggered="RefreshItems"/>
</CascadingValue>
</CascadingValue>

@code {

    [SupplyParameterFromQuery]
    public string Href { get; set; }

    protected override string GetBasePath() => "/posts";

    protected override Dictionary<string, string> GetExtraQueryParams()
    {
        var extra = new Dictionary<string, string>();
        if (!string.IsNullOrEmpty(Href)) extra["href"] = Href;
        return extra;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (string.IsNullOrEmpty(Href))
            {
                NavigationManager.NavigateTo("/feeds");
                return;
            }
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    protected override async Task<List<NewsFeedItem>> GetPostsAsync(int pageSize = 20)
    {
        var decodedUrl = System.Net.WebUtility.UrlDecode(Href);
        var posts = await this.feedClient.GetFeedItemsAsync(new NewsFeed(decodedUrl, -1), Page, pageSize: pageSize, cursorPublishDateOrder: CursorPublishDateOrder, cursorId: CursorId);
        return posts?.ToList() ?? new List<NewsFeedItem>();
    }
}