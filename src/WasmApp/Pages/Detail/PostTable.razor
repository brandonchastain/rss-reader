@inherits PageBase
@implements IDisposable
@rendermode InteractiveWebAssembly
@attribute [StreamRendering]
@attribute [Authorize]
@using System.Net
@using System.Text.RegularExpressions
@using Microsoft.JSInterop
@using Sve.Blazor.InfiniteScroll.Components
@using WasmApp.Pages.Detail

@inject ILogger<Posts> logger
@inject IJSRuntime jsRuntime
@inject NavigationManager NavigationManager

<SectionContent SectionName="toolbar">
    <Toolbar
        filterTag="@filterTag"
        IsFilterUnread="@IsFilterUnread"
        IsFilterSaved="@IsFilterSaved"
        userTags="@userTags"
        ToggleUnreadFilterAsync="@ToggleUnreadFilterAsync"
        ToggleSavedFilterAsync="@ToggleSavedFilterAsync"
        FilterForTag="@FilterForTag"
        IsRefreshing="@_isBackgroundRefreshing"
        OnRefreshRequested="@StartBackgroundRefreshAsync"
        OnRefreshComplete="@OnRefreshComplete"
        IsReadingHeadlines="@_isReadingHeadlines"
        OnToggleReadHeadlines="@ToggleReadHeadlinesAsync"
    />
</SectionContent>

@if (_newPostsCount > 0)
{
    <button class="new-posts-toast" @onclick="LoadNewPostsAsync">
        <i class="fas fa-arrow-up"></i>
        <span>@_newPostsCount new post@(_newPostsCount == 1 ? "" : "s") — tap to load</span>
    </button>
}
else if (_showUpToDate)
{
    <div class="new-posts-toast up-to-date">
        <i class="fas fa-check"></i>
        <span>Up to date</span>
    </div>
}

<div id="post-table" class="table">
    @if (IsLoading && (_flatEntries == null || _flatEntries.Count == 0))
    {
        <div class="loading-spinner-container">
            <div class="spinner"></div>
        </div>
    }
    else if (Posts == null || Posts.Count == 0)
    {
        <div class="no-posts-message">
            <p>No posts found.</p>
        </div>
    }
    else
    {
        @foreach (var entry in _flatEntries)
        {
            @if (entry.IsDayHeader)
            {
                <div @key="@entry.DayKey" class="day-separator @(entry.IsFirstHeader ? "day-separator-first" : "")">@GetDayLabel(entry.Date)</div>
            }
            else
            {
                <PostDetail @key="entry.Post.Id"
                    Post="@entry.Post"
                    FilterTag="@this.filterTag"
                    IsFilterUnread="@this.IsFilterUnread"/>
            }
        }

        <InfiniteScroll ObserverTargetId="observerTarget" ObservableTargetReached="(e) => Next()">
            <div class="row">
                <div id="observerTarget">
                    RssApp
                </div>
            </div>
        </InfiniteScroll>
    }
</div>

@code {
    [CascadingParameter(Name = "Posts")]
    public List<NewsFeedItem> Posts { get; set; }
    
    [CascadingParameter(Name = "Page")]
    private int Page { get; set; }

    [CascadingParameter(Name = "IsLoading")]
    public bool IsLoading { get; set; }

    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    [Parameter]
    public EventCallback<(bool, bool, string, bool)> OnRefreshTriggered { get; set; }

    [Parameter]
    public IFeedClient FeedClient { get; set; }

    public IEnumerable<string> userTags = null;
    public bool IsFilterUnread => FeedClient.IsFilterUnread;
    public bool IsFilterSaved => FeedClient.IsFilterSaved;
    private string filterTag => FeedClient.FilterTag;

    // Pre-computed flat list for plain @foreach — rebuilt only when Posts changes
    private List<TimelineEntry> _flatEntries = new();
    private int _lastPostsCount;

    // Background-refresh state. The refresh runs server-side; we poll for it
    // without blocking the UI and surface a non-disruptive toast when it lands.
    private bool _isBackgroundRefreshing;
    private int _newPostsCount;
    private bool _showUpToDate;
    private CancellationTokenSource _refreshPollCts;

    // Headline-reading mode: speaks each post's title top-to-bottom, opening each
    // post for visual preview as it's read, chaining to the next when speech ends.
    private bool _isReadingHeadlines;
    private string _currentHeadlinePostId;
    private DotNetObjectReference<PostTable> _headlineRef;

    private record TimelineEntry(bool IsDayHeader, DateTime Date, string DayKey, bool IsFirstHeader, NewsFeedItem Post);

    public void Dispose()
    {
        _refreshPollCts?.Cancel();
        _refreshPollCts?.Dispose();
        _headlineRef?.Dispose();
    }

    private async Task StartBackgroundRefreshAsync()
    {
        if (_isBackgroundRefreshing) return;

        _isBackgroundRefreshing = true;
        _showUpToDate = false;
        // Keep any existing "N new posts" toast visible while we re-check, so a
        // second click never throws away posts the user hasn't loaded yet.
        StateHasChanged();

        _refreshPollCts?.Cancel();
        _refreshPollCts = new CancellationTokenSource();
        var token = _refreshPollCts.Token;

        int newCount = 0;
        try
        {
            // Fire-and-forget on the server; it keeps running even if we stop polling.
            await FeedClient.TriggerRefreshAsync();

            // Poll progress without blocking — the user keeps reading meanwhile.
            // The server resets its count at the start of each refresh and
            // accumulates as feeds complete, so the final value is this run's total.
            const int maxSeconds = 180;
            for (int elapsed = 0; elapsed < maxSeconds && !token.IsCancellationRequested; elapsed += 2)
            {
                await Task.Delay(2000, token);
                var status = await FeedClient.GetRefreshStatusAsync();
                if (status == null) continue;
                if (status.NewItemCount > newCount) newCount = status.NewItemCount;
                if (!status.IsRefreshing) break;
            }
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Background refresh polling failed.");
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isBackgroundRefreshing = false;
                // Add this run's new posts to any still-unloaded from before.
                _newPostsCount += newCount;
                _showUpToDate = _newPostsCount == 0;
                StateHasChanged();
                if (_showUpToDate) _ = HideUpToDateSoonAsync();
            }
        }
    }

    private async Task HideUpToDateSoonAsync()
    {
        try
        {
            await Task.Delay(2500);
            _showUpToDate = false;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // best-effort auto-dismiss
        }
    }

    private async Task LoadNewPostsAsync()
    {
        // Stop any in-flight poll so it can't re-add a count for posts we're
        // about to load right now.
        _refreshPollCts?.Cancel();
        _isBackgroundRefreshing = false;
        _newPostsCount = 0;
        _showUpToDate = false;
        StateHasChanged();

        // Reuse the existing force-reset path to reload the timeline from the top.
        await OnRefreshComplete();

        try { await jsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
        {
            _headlineRef = DotNetObjectReference.Create(this);
            this.userTags = await FeedClient.GetUserTagsAsync(CurrentUser);
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        if (Posts != null)
        {
            RebuildFlatEntries();
        }
    }

    private void RebuildFlatEntries()
    {
        if (Posts == null || Posts.Count == _lastPostsCount)
            return;

        _lastPostsCount = Posts.Count;
        var entries = new List<TimelineEntry>(Posts.Count + 50);
        bool isFirstGroup = true;

        foreach (var dayGroup in Posts
            .GroupBy(p => p.ParsedDate?.ToLocalTime().Date ?? DateTime.MinValue)
            .OrderByDescending(g => g.Key))
        {
            var dayKey = $"day-{dayGroup.Key:yyyy-MM-dd}";
            entries.Add(new TimelineEntry(true, dayGroup.Key, dayKey, isFirstGroup, null));
            isFirstGroup = false;

            foreach (var post in dayGroup)
            {
                entries.Add(new TimelineEntry(false, default, null, false, post));
            }
        }

        _flatEntries = entries;
    }

    private async Task ToggleUnreadFilterAsync()
    {
        _lastPostsCount = 0; // force rebuild on next parameter set
        await this.OnRefreshTriggered.InvokeAsync((!this.IsFilterUnread, this.IsFilterSaved, this.filterTag, false));
    }

    private async Task ToggleSavedFilterAsync()
    {
        _lastPostsCount = 0;
        await this.OnRefreshTriggered.InvokeAsync((this.IsFilterUnread, !this.IsFilterSaved, this.filterTag, false));
    }

    private async Task FilterForTag(string tag)
    {
        _lastPostsCount = 0;
        if (this.filterTag == tag)
        {
            tag = null;
        }
        await this.OnRefreshTriggered.InvokeAsync((this.IsFilterUnread, this.IsFilterSaved, tag, false));
    }

    private async Task OnRefreshComplete()
    {
        _lastPostsCount = 0;
        await this.OnRefreshTriggered.InvokeAsync((this.IsFilterUnread, this.IsFilterSaved, this.filterTag, true));
    }

    private async Task Next()
    {
        await this.OnPageChanged.InvokeAsync(this.Page + 1);
        await InvokeAsync(this.StateHasChanged);
    }

    // --- Read-headlines mode ---

    // The posts currently in the list, in display order (day-separators excluded).
    private List<NewsFeedItem> VisiblePosts()
        => _flatEntries.Where(e => !e.IsDayHeader && e.Post != null).Select(e => e.Post).ToList();

    private async Task ToggleReadHeadlinesAsync()
    {
        if (_isReadingHeadlines)
        {
            await PauseReadingHeadlinesAsync();
        }
        else
        {
            await StartReadingHeadlinesAsync();
        }
    }

    private async Task StartReadingHeadlinesAsync()
    {
        var posts = VisiblePosts();
        if (posts.Count == 0) return;

        // Resume from the post we paused on if it's still visible; else start at the top.
        NewsFeedItem start = _currentHeadlinePostId != null
            ? posts.FirstOrDefault(p => p.Id == _currentHeadlinePostId)
            : null;
        start ??= posts[0];

        _isReadingHeadlines = true;
        StateHasChanged();
        await ReadHeadlineAsync(start);
    }

    private async Task PauseReadingHeadlinesAsync()
    {
        _isReadingHeadlines = false;
        try { await jsRuntime.InvokeVoidAsync("stopSpeaking"); } catch { }
        StateHasChanged();
    }

    private async Task ReadHeadlineAsync(NewsFeedItem post)
    {
        if (post == null) { await StopAtEndAsync(); return; }

        _currentHeadlinePostId = post.Id;

        // Open the post for visual preview and bring it into view.
        post.IsBeingPreviewed = true;
        StateHasChanged();
        try { await jsRuntime.InvokeVoidAsync("rssApp.scrollToPost", post.Id); } catch { }

        // Fill in the body in the background so the preview appears while the
        // headline is being read, without delaying the speech.
        if (post.Content == null) _ = LoadHeadlineContentAsync(post);

        // Speak the headline; OnSpeechStopped advances to the next post when it ends.
        try { await jsRuntime.InvokeVoidAsync("speakThisText", CleanTitle(post.Title), _headlineRef); }
        catch { }
    }

    private async Task LoadHeadlineContentAsync(NewsFeedItem post)
    {
        try { post.Content = await FeedClient.GetItemContentAsync(post); }
        catch { post.Content = "[content unavailable]"; }
        await InvokeAsync(StateHasChanged);
    }

    // Invoked from app.js when an utterance ends. Advances to the next headline.
    [JSInvokable]
    public async Task OnSpeechStopped()
    {
        if (!_isReadingHeadlines) return; // paused or stopped

        var posts = VisiblePosts();
        int idx = posts.FindIndex(p => p.Id == _currentHeadlinePostId);

        // Collapse the post we just read so only the current one stays open.
        if (idx >= 0) posts[idx].IsBeingPreviewed = false;

        var next = (idx >= 0 && idx + 1 < posts.Count) ? posts[idx + 1] : null;
        if (next == null) { await StopAtEndAsync(); return; }

        await ReadHeadlineAsync(next);
    }

    private async Task StopAtEndAsync()
    {
        _isReadingHeadlines = false;
        _currentHeadlinePostId = null;
        await InvokeAsync(StateHasChanged);
    }

    private static string CleanTitle(string title)
    {
        if (string.IsNullOrEmpty(title)) return title;
        var cleaned = Regex.Replace(title, "<[^>]+>", string.Empty);
        return WebUtility.HtmlDecode(cleaned);
    }

    private static readonly string[] _months = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    private static readonly string[] _days = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };

    private static string GetDayLabel(DateTime date)
    {
        if (date == DateTime.MinValue) return "Unknown date";
        return $"{_days[(int)date.DayOfWeek]}, {_months[date.Month - 1]} {date.Day} {date.Year}";
    }
}