@inherits PageBase
@implements IDisposable
@rendermode InteractiveWebAssembly
@attribute [StreamRendering]
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Sve.Blazor.InfiniteScroll.Components
@using WasmApp.Pages.Detail

@inject ILogger<Posts> logger
@inject IJSRuntime jsRuntime
@inject NavigationManager NavigationManager

<SectionContent SectionName="toolbar">
    <Toolbar
        filterTag="@filterTag"
        IsFilterUnread="@IsFilterUnread"
        IsFilterSaved="@IsFilterSaved"
        userTags="@userTags"
        ToggleUnreadFilterAsync="@ToggleUnreadFilterAsync"
        ToggleSavedFilterAsync="@ToggleSavedFilterAsync"
        FilterForTag="@FilterForTag"
        OnRefreshComplete="@OnRefreshComplete"
    />
</SectionContent>


<div id="post-table" class="table">
    @if (isLoading && !_showTerminal)
    {
        <div class="loading-spinner-container">
            <div class="spinner"></div>
        </div>
    }
    else if (isLoading && _showTerminal)
    {
        <div class="shell-boot">
            <div class="shell-line shell-cmd">$ rssreader --connect</div>
            <div class="shell-banner">
                <span><span class="comment-slash">// </span><span class="comment-text">rssreader [v1.1]</span></span>
                <span><span class="comment-slash">// </span><span class="comment-text">read what matters to you.</span></span>
            </div>
            @foreach (var msg in _visibleMessages.Take(_visibleMessages.Count - (_hasTimedOut ? 0 : 1)))
            {
                <div class="shell-line"><span class="shell-prompt">&gt;</span> @msg</div>
            }
            @if (!_hasTimedOut && _visibleMessages.Count > 0)
            {
                <div class="shell-line shell-active">
                    <span class="shell-prompt">&gt;</span> @_visibleMessages[^1]@(new string('.', _dotCount))
                </div>
                <div class="shell-line"><span class="shell-cursor">█</span></div>
            }
            @if (_hasTimedOut)
            {
                <div class="shell-line shell-error"><span class="shell-prompt">&gt;</span> ERROR: Connection timed out</div>
                <div class="shell-line shell-cmd">$ <button class="shell-retry-btn" @onclick="Retry">[Retry]</button></div>
            }
        </div>
    }
    else if (Posts == null || Posts.Count == 0)
    {
        @if (_isInitialLoad)
        {
            <div class="loading-spinner-container">
                <div class="spinner"></div>
            </div>
        }
        else
        {
            <div class="no-posts-message">
                <p>No posts found.</p>
            </div>
        }
    }
    else
    {
        <InfiniteScroll ObserverTargetId="observerTarget" ObservableTargetReached="(e) => Next()">
            @{ bool isFirstGroup = true; }
            @foreach (var dayGroup in Posts
                .GroupBy(p => p.ParsedDate?.ToLocalTime().Date ?? DateTime.MinValue)
                .OrderByDescending(g => g.Key))
            {
                <div class="day-separator @(isFirstGroup ? "day-separator-first" : "")">@GetDayLabel(dayGroup.Key)</div>
                isFirstGroup = false;
                <div class="day-group">
                @foreach (var post in dayGroup)
                {
                    <PostDetail @key="post.Id"
                        Post="@post"
                        FilterTag="@this.filterTag"
                        IsFilterUnread="@this.IsFilterUnread"/>
                }
                </div>
            }

            <div class="row">
                <div id="observerTarget">
                    RssApp
                </div>
            </div>
            
        </InfiniteScroll>
    }
</div>

@code {
    [CascadingParameter(Name = "Posts")]
    public List<NewsFeedItem> Posts { get; set; }
    
    [CascadingParameter(Name = "Page")]
    private int Page { get; set; }

    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    [Parameter]
    public EventCallback<(bool, bool, string)> OnRefreshTriggered { get; set; }

    [Parameter]
    public IFeedClient FeedClient { get; set; }

    public IEnumerable<string> userTags = null;
    public bool IsFilterUnread => FeedClient.IsFilterUnread;
    public bool IsFilterSaved => FeedClient.IsFilterSaved;
    private string filterTag => FeedClient.FilterTag;

    private const int MaxPostsToKeep = 100;  // Adjust this number based on your needs
    private const int LoadingTimeoutMs = 30000;
    private const int SpinnerDelayMs = 2000;
    private const int MessageIntervalMs = 1500;
    private const int DotIntervalMs = 500;

    private static readonly string[] _statusMessages =
    {
        "Initializing",
        "Loading configuration",
        "Connecting to feed service",
        "Fetching subscriptions",
        "Loading posts"
    };

    private bool isLoading = true;
    private bool _showTerminal = false;
    private bool _hasTimedOut = false;
    private bool _isInitialLoad = true;
    private List<string> _visibleMessages = new();
    private int _messageIndex = 0;
    private int _dotCount = 0;
    private System.Timers.Timer _timeoutTimer;
    private System.Timers.Timer _spinnerTimer;
    private System.Timers.Timer _messageTimer;
    private System.Timers.Timer _dotTimer;

    public void Dispose()
    {
        _timeoutTimer?.Stop();
        _timeoutTimer?.Dispose();
        _spinnerTimer?.Stop();
        _spinnerTimer?.Dispose();
        _messageTimer?.Stop();
        _messageTimer?.Dispose();
        _dotTimer?.Stop();
        _dotTimer?.Dispose();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
        {
            StartSpinnerTimer();
            this.userTags = await FeedClient.GetUserTagsAsync(CurrentUser);
            StateHasChanged();
        }
    }

    private void StartSpinnerTimer()
    {
        _showTerminal = false;
        _spinnerTimer?.Stop();
        _spinnerTimer?.Dispose();

        // Only escalate to terminal animation on the very first load
        if (!_isInitialLoad) return;

        _spinnerTimer = new System.Timers.Timer(SpinnerDelayMs);
        _spinnerTimer.AutoReset = false;
        _spinnerTimer.Elapsed += (s, e) =>
        {
            if (!isLoading) return;
            _showTerminal = true;
            StartTimeoutTimer();
            StartMessageTimer();
            StartDotTimer();
            InvokeAsync(StateHasChanged);
        };
        _spinnerTimer.Start();
    }

    private void StartMessageTimer()
    {
        _visibleMessages.Clear();
        _messageIndex = 0;
        _visibleMessages.Add(_statusMessages[0]);

        _messageTimer?.Stop();
        _messageTimer?.Dispose();
        _messageTimer = new System.Timers.Timer(MessageIntervalMs);
        _messageTimer.AutoReset = true;
        _messageTimer.Elapsed += (s, e) =>
        {
            if (!isLoading) return;
            _messageIndex++;
            if (_messageIndex < _statusMessages.Length)
            {
                _visibleMessages.Add(_statusMessages[_messageIndex]);
                InvokeAsync(StateHasChanged);
            }
            else
            {
                _messageTimer?.Stop();
            }
        };
        _messageTimer.Start();
    }

    private void StartDotTimer()
    {
        _dotCount = 0;
        _dotTimer?.Stop();
        _dotTimer?.Dispose();
        _dotTimer = new System.Timers.Timer(DotIntervalMs);
        _dotTimer.AutoReset = true;
        _dotTimer.Elapsed += (s, e) =>
        {
            if (!isLoading) return;
            _dotCount = (_dotCount + 1) % 4;
            InvokeAsync(StateHasChanged);
        };
        _dotTimer.Start();
    }

    private void StartTimeoutTimer()
    {
        _hasTimedOut = false;
        _timeoutTimer?.Stop();
        _timeoutTimer?.Dispose();
        _timeoutTimer = new System.Timers.Timer(LoadingTimeoutMs);
        _timeoutTimer.AutoReset = false;
        _timeoutTimer.Elapsed += (s, e) =>
        {
            if (isLoading)
            {
                _hasTimedOut = true;
                InvokeAsync(StateHasChanged);
            }
        };
        _timeoutTimer.Start();
    }

    private void StopTimeoutTimer()
    {
        _spinnerTimer?.Stop();
        _showTerminal = false;
        _timeoutTimer?.Stop();
        _hasTimedOut = false;
        _messageTimer?.Stop();
        _dotTimer?.Stop();
        _dotCount = 0;
    }

    private void Retry()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        // Only stop loading when posts actually arrive.
        // Filter toggles set isLoading=false explicitly after their await completes,
        // so we don't prematurely clear it on intermediate renders with an empty list.
        if (Posts != null && Posts.Count > 0)
        {
            isLoading = false;
            StopTimeoutTimer();
            _isInitialLoad = false;
        }
    }

    private async Task ToggleUnreadFilterAsync()
    {
        isLoading = true;
        StartSpinnerTimer();
        await this.OnRefreshTriggered.InvokeAsync((!this.IsFilterUnread, this.IsFilterSaved, this.filterTag));
        isLoading = false;
        StopTimeoutTimer();
    }

    private async Task ToggleSavedFilterAsync()
    {
        isLoading = true;
        StartSpinnerTimer();
        await this.OnRefreshTriggered.InvokeAsync((this.IsFilterUnread, !this.IsFilterSaved, this.filterTag));
        isLoading = false;
        StopTimeoutTimer();
    }

    private async Task FilterForTag(string tag)
    {
        isLoading = true;
        StartSpinnerTimer();
        if (this.filterTag == tag)
        {
            tag = null;
        }
        await this.OnRefreshTriggered.InvokeAsync((this.IsFilterUnread, this.IsFilterSaved, tag));
        isLoading = false;
        StopTimeoutTimer();
    }

    private async Task OnRefreshComplete()
    {
        // Re-fetch page 0 with current filters without showing loading animation
        await this.OnRefreshTriggered.InvokeAsync((this.IsFilterUnread, this.IsFilterSaved, this.filterTag));
    }

    private async Task Next()
    {
        isLoading = true;
        await this.OnPageChanged.InvokeAsync(this.Page + 1);
        isLoading = false;
        await InvokeAsync(this.StateHasChanged);
    }

    private static readonly string[] _months = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    private static readonly string[] _days = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };

    private static string GetDayLabel(DateTime date)
    {
        if (date == DateTime.MinValue) return "Unknown date";
        return $"{_days[(int)date.DayOfWeek]}, {_months[date.Month - 1]} {date.Day} {date.Year}";
    }
}