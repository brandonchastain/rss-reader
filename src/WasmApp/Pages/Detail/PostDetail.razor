@using System.Threading.Tasks
@inherits PageBase
@implements IDisposable

@rendermode InteractiveWebAssembly
@attribute [StreamRendering]
@attribute [Authorize]

@inject IJSRuntime jsRuntime
@inject NavigationManager navigationManager

@if (Post != null)
{
<div @ref="_postRowRef" class="row @(Post.IsRead ? "post-read" : "post-unread")" @onclick="async () => await HandleClick(Post)" hidden=@(ShouldPostBeHidden(Post))>
    <div class="col thumbnail">
        @{
            var thumbnailUrl = Post.GetThumbnailUrl();
            if (!String.IsNullOrWhiteSpace(thumbnailUrl))
            {
                <img src="@thumbnailUrl" alt="Thumbnail" class="thumbnail" />
            }
            else
            {
                <img src="/placeholder.jpg" alt="Placeholder" class="thumbnail" />
            }
        }
    </div>
    <div class="col">
        <p class="post-title">
            @foreach (var tag in Post.FeedTags)
            {
                <span class="post-tag">@tag</span>
            }
            <a tooltip="@FormatDate(Post.ParsedDate)" href="@Post.Href" @onclick:stopPropagation="true" @onclick:preventDefault="true" @onclick="async () => { await MarkAsReadAsync(Post, true); navigationManager.NavigateTo(Post.Href); }">@Post.Title</a><br/>
            <button class="link" @onclick:stopPropagation="true" @onclick:preventDefault="true" @onclick="async () => await MarkAsReadAsync(Post, !Post.IsRead)">[mark @(!Post.IsRead ? "read" : "unread")]</button><button class="link" @onclick:stopPropagation="true" @onclick:preventDefault="true" @onclick="async () => await SavePost(Post)">[@(!Post.IsSaved ? "save" : "unsave")]</button>
            @if (!String.IsNullOrWhiteSpace(Post.CommentsHref))
            {
                <button class="link" @onclick:stopPropagation="true" @onclick:preventDefault="true" @onclick="() => navigationManager.NavigateTo(Post.CommentsHref)">[comments]</button>
            }
            <a class="post-domain" href="/posts?href=@System.Net.WebUtility.UrlEncode(Post.FeedUrl)" @onclick:stopPropagation="true">@Post.Href.GetRootDomain()</a>
        </p>
    </div>
</div>
<div class="postContent" hidden=@(!Post.IsBeingPreviewed)>
    @if (Post != null)
    {
        <div class="">
            <p>
                Published on @FormatDate(Post.ParsedDate)
            </p>
            <p>
                @if (_isSpeaking)
                {
                    <button class="link" @onclick:stopPropagation="true" @onclick:preventDefault="true" @onclick="() => StopSpeaking()"><i class="fa-solid fa-stop"></i> [stop speaking]</button>
                }
                else
                {
                    <button class="link" @onclick:stopPropagation="true" @onclick:preventDefault="true" @onclick="() => OnSpeakTextClicked(Post)"><i class="fa-solid fa-volume-high"></i> [speak this text]</button>
                }
            </p>
            @if (Post?.GetThumbnailUrl() != null && Post.Content?.TrimStart().IndexOf(Post.GetThumbnailUrl()) < 0)
            {
                <p><img src="@Post.GetThumbnailUrl()" alt="Thumbnail" class="thumbnail" /></p>
            }
            <p>
                @((MarkupString)HtmlSanitizer.Sanitize(Post.Content ?? ""))
            </p>
            <p>
                <button class="btn-link" @onclick="async () => await HandleClick(Post)">Collapse</button>
            </p>
        </div>
    }
    else
    {
        <p>Loading...</p>
    }
</div>
}

@code {
    [Parameter]
    public NewsFeedItem Post { get; set; }

    [Parameter]
    public string FilterTag { get; set; }

    [Parameter]
    public bool IsFilterUnread { get; set; }

    private bool _isSpeaking = false;
    private DotNetObjectReference<PostDetail> _dotNetRef;
    private ElementReference _postRowRef;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    [JSInvokable]
    public void OnSpeechStopped()
    {
        _isSpeaking = false;
        InvokeAsync(StateHasChanged);
    }

    private static string StripHtml(string html)
    {
        var text = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]+>", " ");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\s{2,}", " ");
        return System.Net.WebUtility.HtmlDecode(text).Trim();
    }

    private async Task OnSpeakTextClicked(NewsFeedItem post)
    {
        if (post?.Content != null)
        {
            _isSpeaking = true;
            await jsRuntime.InvokeVoidAsync("speakThisText", StripHtml(post.Content), _dotNetRef);
        }
    }

    private async Task StopSpeaking()
    {
        _isSpeaking = false;
        await jsRuntime.InvokeVoidAsync("stopSpeaking");
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    private bool ShouldPostBeHidden(NewsFeedItem post)
    {
        bool isFilteredByTag = !string.IsNullOrWhiteSpace(this.FilterTag) && !post.FeedTags.Contains(this.FilterTag);
        bool isFilteredByUnread = !post.IsBeingPreviewed && this.IsFilterUnread && post.IsRead;
        return isFilteredByTag || isFilteredByUnread;
    }

    private async Task MarkAsReadAsync(NewsFeedItem item, bool isRead)
    {
        if (isRead && !item.IsRead)
        {
            item.IsRead = true;
        }
        else if (!isRead && item.IsRead)
        {
            item.IsRead = false;
        }

        await InvokeAsync(StateHasChanged);
        try
        {
            await this.feedClient.MarkAsReadAsync(item, item.IsRead);
        }
        catch (Exception)
        {
            // Best-effort — don't crash the UI if the backend is busy (e.g. during refresh).
            // The read state is already updated locally; it will sync on next page load.
        }
    }

    private async Task PreviewPostAsync(NewsFeedItem post)
    {
        bool wasExpanded = post.IsBeingPreviewed;
        if (wasExpanded)
        {
            // Scroll the post row to the top of the viewport BEFORE collapsing.
            // This ensures the content collapses below the fold so the infinite-scroll
            // sentinel never enters the viewport during the DOM shrink.
            await jsRuntime.InvokeVoidAsync("scrollToTopInstant", _postRowRef);
        }

        post.IsBeingPreviewed = !post.IsBeingPreviewed;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SavePost(NewsFeedItem post)
    {
        if (!post.IsSaved)
        {
            post.IsSaved = true;
            await InvokeAsync(StateHasChanged);
            await this.feedClient.SavePostAsync(post);
        }
        else    
        {
            post.IsSaved = false;
            await InvokeAsync(StateHasChanged);
            await this.feedClient.UnsavePostAsync(post);
        }
    }

    private static readonly string[] _months = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    private static readonly string[] _days = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };

    private static string FormatDate(DateTime? date)
    {
        if (date == null) return "";
        var d = date.Value;
        return $"{_days[(int)d.DayOfWeek]}, {_months[d.Month - 1]} {d.Day} {d.Year} {d:h:mm tt}";
    }

    private async Task HandleClick(NewsFeedItem post, bool preview = true)
    {
        if (preview)
        {
            // Update read state immediately in the UI, then fire the API call
            // without blocking content loading. During feed refresh, MarkAsRead
            // competes for the SQLite write lock and can hang for seconds.
            _ = MarkAsReadAsync(post, true);
            await PreviewPostAsync(post);
        }
    }
}