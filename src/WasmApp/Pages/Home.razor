@page "/"
@page "/index"
@using WasmApp.Services
@inject NavigationManager NavigationManager
@inject ILogger<Index> logger
@inject IUserClient userClient

<PageTitle>RssReader | A simple browser-based RSS reader</PageTitle>

<article class="container-fluid py-4">
    <div class="row">
        <div class="col-12 col-lg-10 mx-auto">
            <div class="row">
                <div class="col-12 col-md-6 mb-4 mb-md-0">
                    <h3 class="mb-2" style="color: var(--accent);">// rssreader</h3>
                    <p style="color: var(--text-muted);">a browser-based RSS reader</p>
                </div>
                <div class="col-12 col-md-6">
                    <p style="color: var(--text-muted);">features:</p>
                    <ul class="list-unstyled" style="color: var(--text);">
                        <li class="mb-1"><span style="color: var(--accent);">&gt;</span> subscribe to RSS and Atom feeds</li>
                        <li class="mb-1"><span style="color: var(--accent);">&gt;</span> infinite-scroll timeline</li>
                        <li class="mb-1"><span style="color: var(--accent);">&gt;</span> tag-based feed categories and filters</li>
                        <li class="mb-1"><span style="color: var(--accent);">&gt;</span> save posts for later</li>
                        <li class="mb-1"><span style="color: var(--accent);">&gt;</span> full-text search</li>
                        <li class="mb-1"><span style="color: var(--accent);">&gt;</span> import / export OPML</li>
                        <li class="mb-1"><span style="color: var(--accent);">&gt;</span> responsive (mobile + desktop)</li>
                    </ul>
                </div>
            </div>
            <AuthorizeView>
                <NotAuthorized>
                    <div class="row mt-5">
                        <div class="col-12 text-center">
                            <a href="/.auth/login/aad" class="btn btn-primary btn-lg px-5 py-3" style="font-size: 1.2rem; letter-spacing: 0.05em;">
                                [login / sign-up]
                            </a>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</article>