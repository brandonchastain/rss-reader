@page "/"
@page "/index"
@using WasmApp.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
@inject ILogger<Index> logger
@inject IUserClient userClient
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime

<PageTitle>RssReader | A simple browser-based RSS reader</PageTitle>

<article @ref="_terminalRef" tabindex="0" @onkeydown="HandleKeyDown" style="outline: none;">
    <div class="shell-boot">
        <div class="shell-line shell-cmd">$ rssreader --connect</div>
        <div class="shell-banner">
            <span><span class="comment-slash">// </span><span class="comment-text">rssreader [v1.1]</span></span>
            <span><span class="comment-slash">// </span><span class="comment-text">read what matters to you.</span></span>
        </div>
        <div class="shell-line"><span class="shell-prompt">&gt;</span> Initializing</div>
        <div class="shell-line"><span class="shell-prompt">&gt;</span> Loading configuration...</div>
        <div class="shell-line"><span class="shell-prompt">&gt;</span> Connected.</div>
        <div class="shell-line" style="margin-top: 1rem;"><span class="shell-prompt">&gt;</span> subscribe to RSS and Atom feeds</div>
        <div class="shell-line"><span class="shell-prompt">&gt;</span> infinite-scroll timeline</div>
        <div class="shell-line"><span class="shell-prompt">&gt;</span> save posts for later</div>
        <AuthorizeView>
            <NotAuthorized>
                @* Desktop: keyboard prompt *@
                <div class="shell-line shell-cmd desktop-only" style="margin-top: 1.5rem;">$ press [ENTER] to continue<span class="shell-cursor">█</span></div>
                @* Mobile: button *@
                <div class="mobile-only" style="margin-top: 1.5rem;">
                    <a href="/.auth/login/aad" class="btn btn-outline-success btn-sm" style="font-family: inherit; letter-spacing: 0.05em;">Login / Sign Up</a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</article>

@code {
    // Auto-focus for keyboard handling; FocusAsync runs after first render
    private ElementReference _terminalRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Redirect authenticated users to timeline without a full page reload
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User?.Identity?.IsAuthenticated == true)
            {
                await JSRuntime.InvokeVoidAsync("rssApp.setReturningUser");
                NavigationManager.NavigateTo("/timeline", replace: true);
                return;
            }

            await _terminalRef.FocusAsync();
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            NavigationManager.NavigateTo("/.auth/login/aad", forceLoad: true);
        }
    }
}