{
  "routes": [
    {
      "route": "/api/healthz",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/timeline*",
      "rewrite": "/index.html",
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/feeds*",
      "rewrite": "/index.html",
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/tags*",
      "rewrite": "/index.html",
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/search*",
      "rewrite": "/index.html",
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/posts*",
      "rewrite": "/index.html",
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/account*",
      "rewrite": "/index.html",
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/_framework/blazor.boot.json",
      "headers": {
        "cache-control": "no-cache"
      }
    },
    {
      "route": "/_framework/blazor.webassembly.js",
      "headers": {
        "cache-control": "no-cache"
      }
    },
    {
      "route": "/_framework/dotnet.js",
      "headers": {
        "cache-control": "no-cache"
      }
    },
    {
      "route": "/_framework/dotnet.native.wasm",
      "headers": {
        "cache-control": "no-cache"
      }
    },
    {
      "route": "/_framework/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/.auth/*", "/timeline*", "/feeds*", "/tags*", "/search*", "/posts*"]
  },
  "globalHeaders":{
    "cache-control": "no-cache"
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "platform": {
    "apiRuntime": "node:20"
  }
}